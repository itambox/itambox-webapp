# ==============================================================================
# ITAMbox environment variables — template
# ==============================================================================
# Copy to '.env' and edit. Real env vars always win over values in this file.
#
# The settings loader fails closed: if neither ITAMBOX_ENV nor ITAMBOX_DEBUG is
# set, the app runs in PRODUCTION mode. For local development set ITAMBOX_ENV=dev
# (or ITAMBOX_DEBUG=True) below.
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment selection
# ------------------------------------------------------------------------------
# dev | prod. Leave unset to fail closed to prod.
ITAMBOX_ENV=dev
# Enable Django debug mode. NEVER True in production.
ITAMBOX_DEBUG=True

# ------------------------------------------------------------------------------
# Public base URL  (recommended in production)
# ------------------------------------------------------------------------------
# Used to build absolute URLs in QR code labels and outbound links.
# Must NOT have a trailing slash. Leave blank in dev (bare-tag QR codes work
# without it; the app uses the itambox:<tag> scheme by default).
# ITAMBOX_BASE_URL=https://itam.example.com

# ------------------------------------------------------------------------------
# Core / security  (required in production)
# ------------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# The app refuses to boot in prod with the insecure fallback key.
#
# *** CRITICAL: This key derives the Fernet encryption key used to store ***
# *** sensitive values (e.g. SMTP passwords). If you lose or rotate it,  ***
# *** all encrypted fields become permanently unreadable. Back up .env    ***
# *** together with every database dump — they are a unit.                ***
ITAMBOX_SECRET_KEY=

# Comma-separated hosts the site may serve. Keep 127.0.0.1 so the container
# health probe works.
ITAMBOX_ALLOWED_HOSTS=localhost,127.0.0.1

# Origins trusted for cross-origin POST/PUT (scheme required), e.g.
# https://itam.example.com
ITAMBOX_CSRF_TRUSTED_ORIGINS=

# HTTPS hardening (only applied in prod). Leave SSL redirect on unless TLS is
# terminated upstream and you handle redirects there.
ITAMBOX_SECURE_SSL_REDIRECT=True
ITAMBOX_HSTS_SECONDS=31536000
ITAMBOX_HSTS_INCLUDE_SUBDOMAINS=True
ITAMBOX_HSTS_PRELOAD=True

# Logging level: DEBUG | INFO | WARNING | ERROR
ITAMBOX_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database (PostgreSQL 15+ required)
# ------------------------------------------------------------------------------
ITAMBOX_DB_ENGINE=django.db.backends.postgresql
ITAMBOX_DB_NAME=itambox
ITAMBOX_DB_USER=itambox
ITAMBOX_DB_PASSWORD=itambox
ITAMBOX_DB_HOST=localhost
ITAMBOX_DB_PORT=5432
ITAMBOX_DB_CONN_MAX_AGE=300
# prefer | require | verify-full  (use require/verify-full for managed/remote PG)
ITAMBOX_DB_SSLMODE=prefer

# ------------------------------------------------------------------------------
# Cache / rate limiting
# ------------------------------------------------------------------------------
# locmem | redis. Use a Redis-protocol server in production (Valkey recommended —
# BSD-licensed fork of Redis) so throttles + rate-limit counters are shared
# across gunicorn workers.
ITAMBOX_CACHE_BACKEND=locmem
ITAMBOX_REDIS_URL=redis://127.0.0.1:6379/1
ITAMBOX_CACHE_TIMEOUT=300
# Cache alias used for the login/invite rate limiter (point at redis in prod).
RATELIMIT_CACHE=default

# ------------------------------------------------------------------------------
# Email (used in prod; dev uses a local SMTP catcher automatically)
# ------------------------------------------------------------------------------
ITAMBOX_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
ITAMBOX_EMAIL_HOST=localhost
ITAMBOX_EMAIL_PORT=587
ITAMBOX_EMAIL_HOST_USER=
ITAMBOX_EMAIL_HOST_PASSWORD=
ITAMBOX_EMAIL_USE_TLS=True
ITAMBOX_EMAIL_USE_SSL=False
ITAMBOX_DEFAULT_FROM_EMAIL=ITAMbox <no-reply@example.com>

# ------------------------------------------------------------------------------
# Static / media paths (optional overrides)
# ------------------------------------------------------------------------------
# ITAMBOX_STATIC_ROOT=/app/staticfiles
# ITAMBOX_MEDIA_ROOT=/app/media

# ------------------------------------------------------------------------------
# Plugins (optional)
# ------------------------------------------------------------------------------
# Comma-separated importable plugin packages. Each must be installed.
# ITAMBOX_PLUGINS=itambox_esign

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
ITAMBOX_CORS_ALLOW_ALL_ORIGINS=False
ITAMBOX_CORS_ALLOWED_ORIGINS=

# ------------------------------------------------------------------------------
# Multi-Tenant LDAP / SAML / OIDC SSO  (JSON keyed by tenant slug)
# ------------------------------------------------------------------------------
# ITAMBOX_TENANT_LDAP_CONFIGS='{"tenant-alpha": {"SERVER_URI": "ldap://ldap.alpha-corp.com", "BIND_DN": "cn=admin,dc=alpha-corp,dc=com", "BIND_PASSWORD": "secretpassword", "USER_SEARCH_BASE": "ou=users,dc=alpha-corp,dc=com", "USER_SEARCH_FILTER": "(uid=%(user)s)", "REQUIRE_GROUP": "cn=itambox-users,ou=groups,dc=alpha-corp,dc=com"}}'
# ITAMBOX_TENANT_SAML_CONFIGS='{"tenant-alpha": {"entityid": "https://alpha.itambox.com/saml2/metadata/", "metadata": {"remote": [{"url": "https://identity.alpha-corp.com/federation/metadata"}]}}}'
# ITAMBOX_TENANT_OIDC_CONFIGS='{"tenant-alpha": {"OIDC_RP_CLIENT_ID": "...", "OIDC_RP_CLIENT_SECRET": "...", "OIDC_OP_AUTHORIZATION_ENDPOINT": "https://idp/authorize", "OIDC_OP_TOKEN_ENDPOINT": "https://idp/token", "OIDC_OP_USER_ENDPOINT": "https://idp/userinfo"}}'
