# ==============================================================================
# AssetBox Local Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and modify settings for local development or production.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Settings
# ------------------------------------------------------------------------------
# Set the secret key for production (random 50-character string).
# Defaults to a dev-safe key if left blank.
ASSETBOX_SECRET_KEY=django-insecure-dev-only-change-me-in-production

# Enable/disable Django debug mode (True/False).
ASSETBOX_DEBUG=True

# Comma-separated list of hosts/domains the site can serve.
ASSETBOX_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------------------
# Database Configurations
# ------------------------------------------------------------------------------
# PostgreSQL is the required database engine for AssetBox.
ASSETBOX_DB_ENGINE=django.db.backends.postgresql
ASSETBOX_DB_NAME=assetbox
ASSETBOX_DB_USER=assetbox
ASSETBOX_DB_PASSWORD=assetbox
ASSETBOX_DB_HOST=localhost
ASSETBOX_DB_PORT=5432
ASSETBOX_DB_CONN_MAX_AGE=300
ASSETBOX_DB_SSLMODE=prefer

# ------------------------------------------------------------------------------
# Cache Configurations
# ------------------------------------------------------------------------------
# Supported backends: locmem (local memory), redis
ASSETBOX_CACHE_BACKEND=locmem
ASSETBOX_REDIS_URL=redis://127.0.0.1:6379/1
ASSETBOX_CACHE_TIMEOUT=300

# ------------------------------------------------------------------------------
# Production Security Configurations (Only used when ASSETBOX_DEBUG=False)
# ------------------------------------------------------------------------------
ASSETBOX_SECURE_SSL_REDIRECT=False
ASSETBOX_HSTS_SECONDS=31536000
ASSETBOX_HSTS_INCLUDE_SUBDOMAINS=True
ASSETBOX_HSTS_PRELOAD=True
