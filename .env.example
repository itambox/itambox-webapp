# ==============================================================================
# ITAMbox Local Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and modify settings for local development or production.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Settings
# ------------------------------------------------------------------------------
# Set the secret key for production (random 50-character string).
# Defaults to a dev-safe key if left blank.
ITAMBOX_SECRET_KEY=django-insecure-dev-only-change-me-in-production

# Enable/disable Django debug mode (True/False).
ITAMBOX_DEBUG=True

# Comma-separated list of hosts/domains the site can serve.
ITAMBOX_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------------------
# Database Configurations
# ------------------------------------------------------------------------------
# PostgreSQL is the required database engine for ITAMbox.
ITAMBOX_DB_ENGINE=django.db.backends.postgresql
ITAMBOX_DB_NAME=itambox
ITAMBOX_DB_USER=itambox
ITAMBOX_DB_PASSWORD=itambox
ITAMBOX_DB_HOST=localhost
ITAMBOX_DB_PORT=5432
ITAMBOX_DB_CONN_MAX_AGE=300
ITAMBOX_DB_SSLMODE=prefer

# ------------------------------------------------------------------------------
# Cache Configurations
# ------------------------------------------------------------------------------
# Supported backends: locmem (local memory), redis
ITAMBOX_CACHE_BACKEND=locmem
ITAMBOX_REDIS_URL=redis://127.0.0.1:6379/1
ITAMBOX_CACHE_TIMEOUT=300

# ------------------------------------------------------------------------------
# Production Security Configurations (Only used when ITAMBOX_DEBUG=False)
# ------------------------------------------------------------------------------
ITAMBOX_SECURE_SSL_REDIRECT=False
ITAMBOX_HSTS_SECONDS=31536000
ITAMBOX_HSTS_INCLUDE_SUBDOMAINS=True
ITAMBOX_HSTS_PRELOAD=True
