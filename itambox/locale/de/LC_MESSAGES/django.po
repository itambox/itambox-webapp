#, python-brace-format
msgid ""
"API Token generated successfully! Make sure to copy your new personal access"
" token now, as you won't be able to see it again: <code>{token_key}</code>"
msgstr ""
"API-Token erfolgreich generiert! Kopieren Sie jetzt Ihren persönlichen "
"Token, da Sie ihn später nicht mehr sehen können: <code>{token_key}</code>"

msgid "API Token has been revoked."
msgstr "API-Token wurde widerrufen."

#, python-brace-format
msgid "Unsubscribed from {name}."
msgstr "Abonnement von {name} beendet."

#, python-brace-format
msgid "Bookmarked {name}."
msgstr "Lesezeichen für {name} gesetzt."

#, python-brace-format
msgid "Bookmark removed from {name}."
msgstr "Lesezeichen für {name} entfernt."

#, python-brace-format
msgid "Unwatched {name}."
msgstr "Beobachtung von {name} beendet."

#, python-brace-format
msgid "Now watching {name}."
msgstr "{name} wird jetzt beobachtet."

msgid "You cannot delete your own user account."
msgstr "Sie können Ihr eigenes Benutzerkonto nicht löschen."

msgid "Status after check-in"
msgstr "Status nach Einbuchung"

msgid "Leave blank to revert each asset to its pre-checkout status."
msgstr ""
"Leer lassen, um jedes Asset auf seinen Status vor der Herausgabe "
"zurückzusetzen."

msgid "Return to location"
msgstr "Zurück an Lagerort"

msgid "Optional. Leave blank to keep each asset's current location."
msgstr ""
"Optional. Leer lassen, um den aktuellen Lagerort jedes Assets beizubehalten."

msgid "Check-in date"
msgstr "Rückgabedatum"

msgid "Disposal date"
msgstr "Entsorgungsdatum"

msgid "Asset holder"
msgstr "Asset-Inhaber"

msgid "Parent asset"
msgstr "Übergeordnetes Asset"

msgid "Status after check-out"
msgstr "Status nach Herausgabe"

msgid "Check-out date"
msgstr "Herausgabedatum"

msgid "Expected check-in date"
msgstr "Erwartetes Rückgabedatum"

msgid "Choose exactly one target — a holder, a location, or a parent asset."
msgstr ""
"Wählen Sie genau ein Ziel — einen Inhaber, einen Lagerort oder ein "
"übergeordnetes Asset."

msgid "Already disposed — will be skipped."
msgstr "Bereits entsorgt — wird übersprungen."

msgid "Not checked out — nothing to return."
msgstr "Nicht herausgegeben — nichts zurückzugeben."

msgid "Cannot check out — %(status)s."
msgstr "Kann nicht herausgegeben werden — %(status)s."

msgid "Currently assigned to %(holder)s — will be reassigned."
msgstr "Derzeit %(holder)s zugewiesen — wird neu zugewiesen."

msgid "No assets selected for check-in."
msgstr "Keine Assets für die Einbuchung ausgewählt."

msgid "No assets selected for check-out."
msgstr "Keine Assets für die Herausgabe ausgewählt."

msgid "No assets selected for disposal."
msgstr "Keine Assets für die Entsorgung ausgewählt."

msgid "A disposal date is required."
msgstr "Ein Entsorgungsdatum ist erforderlich."

msgid ""
"Select exactly one check-out target: a holder, a location, or a parent "
"asset."
msgstr ""
"Wählen Sie genau ein Herausgabe-Ziel: einen Inhaber, einen Lagerort oder ein"
" übergeordnetes Asset."

msgid ""
"Asynchronous check-in job '%(job)s' enqueued. Tracking progress in real-"
"time."
msgstr ""
"Asynchroner Einbuchungs-Job '%(job)s' eingereiht. Fortschritt wird in "
"Echtzeit verfolgt."

msgid ""
"Asynchronous check-out job '%(job)s' enqueued. Tracking progress in real-"
"time."
msgstr ""
"Asynchroner Herausgabe-Job '%(job)s' eingereiht. Fortschritt wird in "
"Echtzeit verfolgt."

msgid ""
"Asynchronous disposal job '%(job)s' enqueued. Tracking progress in real-"
"time."
msgstr ""
"Asynchroner Entsorgungs-Job '%(job)s' eingereiht. Fortschritt wird in "
"Echtzeit verfolgt."

msgid "Bulk Check-in Failed"
msgstr "Sammel-Einbuchung fehlgeschlagen"

msgid "Bulk Check-in Complete"
msgstr "Sammel-Einbuchung abgeschlossen"

msgid "Bulk Check-in Error"
msgstr "Fehler bei der Sammel-Einbuchung"

msgid "All hardware check-ins failed. View logs for details."
msgstr "Alle Einbuchungen sind fehlgeschlagen. Details in den Protokollen."

msgid "Checked in %(count)s asset(s)."
msgstr "%(count)s Asset(s) eingebucht."

msgid "A system exception occurred during check-in: %(error)s"
msgstr "Während der Einbuchung ist eine Systemausnahme aufgetreten: %(error)s"

msgid "Bulk Disposal Failed"
msgstr "Sammel-Entsorgung fehlgeschlagen"

msgid "Bulk Disposal Complete"
msgstr "Sammel-Entsorgung abgeschlossen"

msgid "Bulk Disposal Error"
msgstr "Fehler bei der Sammel-Entsorgung"

msgid "All hardware disposals failed. View logs for details."
msgstr "Alle Entsorgungen sind fehlgeschlagen. Details in den Protokollen."

msgid "Disposed %(count)s asset(s)."
msgstr "%(count)s Asset(s) entsorgt."

msgid "A system exception occurred during disposal: %(error)s"
msgstr "Während der Entsorgung ist eine Systemausnahme aufgetreten: %(error)s"

