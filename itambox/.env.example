# ITAMbox environment configuration example.
# Copy to .env and adjust values before starting the server.
# ITAMbox reads this file automatically from BASE_DIR or BASE_DIR/../ at startup.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
ITAMBOX_ENV=dev                           # dev | prod  (fails closed to prod when unset)
ITAMBOX_SECRET_KEY=change-me-in-production

# Public base URL for QR labels and outbound links (no trailing slash).
ITAMBOX_BASE_URL=https://itam.example.com

# ---------------------------------------------------------------------------
# Database (PostgreSQL required — SQLite is explicitly rejected)
# ---------------------------------------------------------------------------
ITAMBOX_DB_NAME=itambox
ITAMBOX_DB_USER=itambox
ITAMBOX_DB_PASSWORD=itambox
ITAMBOX_DB_HOST=localhost
ITAMBOX_DB_PORT=5432

# ---------------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------------
ITAMBOX_CACHE_BACKEND=locmem              # locmem | redis (Redis protocol; run Valkey in prod)
ITAMBOX_REDIS_URL=redis://127.0.0.1:6379/1
RATELIMIT_CACHE=default

# ---------------------------------------------------------------------------
# Currency
# ---------------------------------------------------------------------------
# ISO 4217 fallback for money display; {{ value|money:obj }} resolves tenant
# currency first, then this setting.  Display-only — no exchange-rate math.
ITAMBOX_DEFAULT_CURRENCY=EUR

# ---------------------------------------------------------------------------
# Docs
# ---------------------------------------------------------------------------
# Filesystem path to the compiled MkDocs output (static/docs/).
# Defaults to BASE_DIR/docs if unset.
# ITAMBOX_DOCS_ROOT=/srv/itambox/static/docs

# ---------------------------------------------------------------------------
# Organization hierarchy
# ---------------------------------------------------------------------------
# Show Regions and Site Groups in the sidebar.  Off by default — most installs
# do not need the extra hierarchy layer.
ITAMBOX_ENABLE_EXTENDED_ORG_HIERARCHY=False

# ---------------------------------------------------------------------------
# Custody & Compliance
# ---------------------------------------------------------------------------
# Require a digital signature when a custody receipt is signed in the UI.
ITAMBOX_REQUIRE_CUSTODY_SIGNIN=True
# Allow custody templates that are not scoped to a specific tenant.
ITAMBOX_ALLOW_GLOBAL_CUSTODY_TEMPLATES=True

# ---------------------------------------------------------------------------
# Email (prod only — ignored in dev)
# ---------------------------------------------------------------------------
# ITAMBOX_SERVER_EMAIL=noreply@itam.example.com

# ---------------------------------------------------------------------------
# Integrations (JSON blobs, optional)
# ---------------------------------------------------------------------------
# ITAMBOX_TENANT_LDAP_CONFIGS={}
# ITAMBOX_TENANT_SAML_CONFIGS={}
# ITAMBOX_TENANT_OIDC_CONFIGS={}
# ITAMBOX_TENANT_INTUNE_CONFIGS={}
