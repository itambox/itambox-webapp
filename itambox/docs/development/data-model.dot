    "organization.TenantGroup" [fillcolor="#E2F4F3", label="TenantGroup"];
    "organization.TenantResourceGrant" [fillcolor="#E2F4F3", label="TenantResourceGrant"];
  }

  subgraph cluster_assets {
    label="assets";
    color="#98A2B3";
